# 이메일 발송을 위한 SMTP 설정 (Google Gmail 기준)
# 1. Google 계정 설정 -> 보안 -> 2단계 인증 사용 설정
# 2. 2단계 인증 하단 '앱 비밀번호' 메뉴로 이동 (또는 검색창에 '앱 비밀번호' 검색)
# 3. 앱 선택: '메일', 기기 선택: 'Windows 컴퓨터' 등으로 설정하고 생성
# 4. 발급된 16자리 비밀번호(띄어쓰기 없이)를 EMAIL_HOST_PASSWORD에 입력하세요.

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=본인의_구글_이메일@gmail.com
EMAIL_HOST_PASSWORD=발급받은_16자리_앱_비밀번호

# 유튜브 검색용 API 설정 (Google Cloud Console)
# 1. Google Cloud Console(console.cloud.google.com) 접속 및 프로젝트 생성
# 2. 'API 및 서비스' -> '라이브러리'에서 'YouTube Data API v3' 검색 후 '사용' 클릭
# 3. 'API 및 서비스' -> '사용자 인증 정보' -> '사용자 인증 정보 만들기' -> 'API 키' 선택
# 4. 발급된 API 키를 아래에 입력하세요.

YOUTUBE_API_KEY=발급받은_유튜브_API_키
